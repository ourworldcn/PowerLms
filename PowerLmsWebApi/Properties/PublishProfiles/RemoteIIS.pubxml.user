<?xml version="1.0" encoding="utf-8"?>
<!--
  发布辅助文件：仅记录用户名，不保存密码。
  发布时 VS 会弹窗询问密码，此文件可安全入库。
-->
<Project>
  <PropertyGroup>
    <UserName>administrator</UserName>
    <_SavePWD>false</_SavePWD>
    <History>True|2026-03-19T00:52:27.8275193Z||;False|2026-03-19T08:51:55.2695226+08:00||;True|2026-03-10T20:07:35.5276986+08:00||;</History>
    <LastFailureDetails />
  </PropertyGroup>
</Project>