  <PropertyGroup>
    <UserName>administrator</UserName>
    <_SavePWD>false</_SavePWD>
    <History>True|2026-03-20T08:35:05.1526446Z||;True|2026-03-20T16:23:08.9558077+08:00||;False|2026-03-20T16:16:40.7564532+08:00||;</History>
    <LastFailureDetails />
  </PropertyGroup>
</Project>