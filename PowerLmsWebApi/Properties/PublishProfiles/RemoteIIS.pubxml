<?xml version="1.0" encoding="utf-8"?>
<!--
  WebDeploy 远程发布到 IIS 的发布配置文件
  使用前请将下列占位符替换为实际值：
    YOUR_SERVER_IP_OR_DOMAIN  - 服务器 IP 或域名
    YOUR_IIS_SITE_NAME        - IIS 中的网站名称（如 Default Web Site）
    YOUR_WINDOWS_USERNAME     - 服务器 Windows 用户名（需有部署权限）
  密码保存在同目录的 RemoteIIS.pubxml.user 文件中（不提交到 Git）
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <PublishProvider>IISWebDeployFindWhat</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish />
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <TargetFramework>net6.0</TargetFramework>
    <ProjectGuid>aa2300ec-165b-419e-a2cb-30ed353d873e</ProjectGuid>
    <SelfContained>false</SelfContained>
    <EnvironmentName>Production</EnvironmentName>
    <MSDeployServiceURL>https://101.200.75.226:8172/msdeploy.axd</MSDeployServiceURL>
    <DeployIisAppPath>PowerLms</DeployIisAppPath>
    <UserName>administrator</UserName>
    <AuthType>Basic</AuthType>
    <SkipExtraFilesOnServer>false</SkipExtraFilesOnServer>
    <EnableMSDeployBackup>false</EnableMSDeployBackup>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <!-- 发布前自动放置维护页，释放文件锁，解决"文件被占用导致部署失败"问题 -->
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
    <RemoteSitePhysicalPath />
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <_SavePWD>false</_SavePWD>
    <!-- 远程服务器应用程序池名称，用于发布前后自动停止/启动 -->
    <DeployAppPoolName>PowerLms</DeployAppPoolName>
    <!-- 独立保存原始 MSDeploy URL，避免 MSDeployPublish 执行后篡改 MSDeployServiceURL 导致 site 参数重复 -->
    <MSDeployServiceURLBase>$(MSDeployServiceURL)</MSDeployServiceURLBase>
  </PropertyGroup>

  <!-- 发布前：通过 msdeploy recycleApp 停止远程应用程序池，等待文件锁释放 -->
  <Target Name="StopRemoteAppPool" BeforeTargets="MSDeployPublish">
    <Message Text="正在停止远程应用程序池 $(DeployAppPoolName) ..." Importance="high" />
    <Exec Command='"C:\Program Files\IIS\Microsoft Web Deploy V3\msdeploy.exe" -verb:sync -source:recycleApp -dest:recycleApp="$(DeployAppPoolName)",recycleMode="StopAppPool",computerName="$(MSDeployServiceURLBase)?site=$(DeployIisAppPath)",userName="$(UserName)",password="$(Password)",authType="$(AuthType)" -allowUntrusted' IgnoreExitCode="true" />
    <Message Text="等待 5 秒让文件锁释放..." Importance="high" />
    <Exec Command="powershell -Command Start-Sleep -Seconds 5" />
  </Target>

  <!-- 发布后：重新启动远程应用程序池 -->
  <Target Name="StartRemoteAppPool" AfterTargets="MSDeployPublish">
    <Message Text="正在启动远程应用程序池 $(DeployAppPoolName) ..." Importance="high" />
    <Exec Command='"C:\Program Files\IIS\Microsoft Web Deploy V3\msdeploy.exe" -verb:sync -source:recycleApp -dest:recycleApp="$(DeployAppPoolName)",recycleMode="StartAppPool",computerName="$(MSDeployServiceURLBase)?site=$(DeployIisAppPath)",userName="$(UserName)",password="$(Password)",authType="$(AuthType)" -allowUntrusted' IgnoreExitCode="true" />
  </Target>
</Project>